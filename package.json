  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.3.10",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=25.0.0"
  },
  "name": "al-iyaal-kids",
  "packageManager": "bun@1.3.10",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ragaeeb/al-iyaal-kids.git"
  },
  "scripts": {
    "build": "bun run tauri:build",
    "check": "bun run typecheck && bun run lint && bun run test",
    "dev": "bun run tauri:dev",
    "format": "biome format --write .",
    "icons:check": "bun run icons:sync && test -f src-tauri/icons/icon.icns",
    "icons:sync": "bun ./scripts/sync-icons.ts",
    "lint": "biome check .",
    "postinstall": "bun run yap:sync",
    "preview": "vite preview",
    "release": "semantic-release",
    "sign:macos": "./scripts/sign-notarize-macos.sh",
    "tauri": "tauri",
    "tauri:build": "bun run version:sync && bun run icons:sync && bun run yap:sync && tauri build",
    "tauri:dev": "bun run version:sync && bun run icons:sync && bun run yap:sync && tauri dev",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "version:sync": "bun ./scripts/sync-version.ts",
    "web:build": "tsc --noEmit && vite build",
    "web:dev": "vite",
    "yap:sync": "./scripts/sync-yap.sh"
  },
  "type": "module",
  "version": "1.1.0"
}
